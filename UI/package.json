{
    "name": "frontend",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev --host 0.0.0.0",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint ./src/",
        "lint:ci": "eslint ./src/ --no-fix --format=compact",
        "test:unit": "vitest",
        "test": "npm run test:unit -- --run && npm run test:e2e",
        "test:e2e": "playwright test",
        "gen:openapi": "openapi-typescript ../openapi.yaml --output ./src/lib/api/openapi.d.ts"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.5",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@iconify-json/ph": "^1.2.2",
        "@iconify/json": "^2.2.469",
        "@iconify/svelte": "^5.2.1",
        "@playwright/test": "^1.59.1",
        "@poppanator/sveltekit-svg": "^7.0.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@svelte-put/inline-svg": "^4.0.2",
        "@svelte-put/swipeable": "^1.1.0",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/enhanced-img": "^0.10.4",
        "@sveltejs/kit": "^2.59.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^25.6.0",
        "@vitest/browser-playwright": "^4.1.5",
        "cssnano": "^7.1.7",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-formatter-compact": "^9.0.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.6.0",
        "mdsvex": "^0.12.7",
        "openapi-typescript": "^7.13.0",
        "playwright": "^1.59.1",
        "postcss": "^8.5.13",
        "postcss-preset-env": "^11.2.1",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "rehype-external-links": "^3.0.0",
        "remark-gfm": "^4.0.1",
        "svelte": "^5.55.5",
        "svelte-check": "^4.4.7",
        "ts-proto": "^2.11.6",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "unplugin-fonts": "^2.0.0",
        "unplugin-icons": "^23.0.1",
        "vite": "^8.0.10",
        "vitest": "^4.1.5",
        "vitest-browser-svelte": "^2.1.1"
    },
    "dependencies": {
        "@floating-ui/dom": "^1.7.6",
        "date-fns": "^4.1.0",
        "openapi-fetch": "^0.17.0"
    },
    "overrides": {
        "openapi-typescript": {
            "typescript": "$typescript"
        }
    }
}
